---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
---

<BaseLayout title="404 — Page Not Found">
  <Header slot="header" />

  <div class="flex flex-col items-center justify-center text-center py-24">

    <!-- Big 404 -->
    <h1 class="text-8xl font-bold text-accent-500 mb-4">404</h1>

    <h2 class="text-2xl font-semibold mb-3">Page Not Found</h2>

    <p class="text-gray-500 dark:text-gray-400 max-w-md mb-8">
      Looks like this page doesn't exist or was moved. 
      Try going back to the homepage or searching for what you need.
    </p>

    <div class="flex items-center gap-4">
      <a href="/" class="btn-primary px-6 py-2.5 rounded-lg text-sm font-medium">
        Go Home
      </a>
      <a href="/blog" class="btn-ghost px-6 py-2.5 rounded-lg text-sm font-medium border border-gray-200 dark:border-gray-700">
        Browse Blog
      </a>
    </div>

  </div>

  <Footer slot="footer" />
</BaseLayout>
