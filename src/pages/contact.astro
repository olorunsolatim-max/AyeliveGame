---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Contact — iSamuelDev">
  <Header slot="header" />

  <div class="max-w-2xl mx-auto">
    <h1 class="text-3xl font-bold mb-2">Contact</h1>
    <p class="text-gray-500 dark:text-gray-400 mb-10">
      Have a question, suggestion, or collaboration idea? Reach out.
    </p>

    <form
      action="https://formspree.io/f/xeevyorg"
      method="POST"
      class="rounded-xl border border-gray-200 dark:border-gray-800 p-6 space-y-5"
    >
      <input type="hidden" name="_next" value="https://isamueldev.vercel.app/contact/" />

      <div>
        <label class="block text-sm font-medium mb-1.5">Name</label>
        <input
          type="text"
          name="name"
          required
          placeholder="Your name"
          class="w-full px-4 py-2.5 rounded-lg bg-gray-100 dark:bg-gray-800 text-sm focus:outline-none focus:ring-2 focus:ring-accent-500"
        />
      </div>

      <div>
        <label class="block text-sm font-medium mb-1.5">Email</label>
        <input
          type="email"
          name="email"
          required
          placeholder="your@email.com"
          class="w-full px-4 py-2.5 rounded-lg bg-gray-100 dark:bg-gray-800 text-sm focus:outline-none focus:ring-2 focus:ring-accent-500"
        />
      </div>

      <div>
        <label class="block text-sm font-medium mb-1.5">Message</label>
        <textarea
          name="message"
          rows="5"
          required
          placeholder="Write your message here..."
          class="w-full px-4 py-2.5 rounded-lg bg-gray-100 dark:bg-gray-800 text-sm focus:outline-none focus:ring-2 focus:ring-accent-500 resize-none"
        ></textarea>
      </div>

      <button
        type="submit"
        class="w-full btn-primary py-3 rounded-lg text-sm font-medium"
      >
        Send Message
      </button>

      <p class="text-xs text-gray-400 text-center">
        Or email directly at
        <a href="mailto:hello@isamueldev.com" class="text-accent-500 hover:underline">
          okesunday503@gmail.com
        </a>
      </p>

    </form>
  </div>

  <Footer slot="footer" />
</BaseLayout>
