---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);

const sortedPosts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Blog — All Posts">
  <Header slot="header" />

  <div class="mb-10">
    <h1 class="text-3xl font-bold mb-2">All Posts</h1>
    <p class="text-gray-500 dark:text-gray-400 text-sm">
      {sortedPosts.length} posts published
    </p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-12">
    {sortedPosts.map(post => (
      <a
        href={`/blog/${post.slug}`}
        class="group flex gap-4 rounded-xl border border-gray-200 dark:border-gray-800 hover:border-accent-500 transition-all duration-300 p-3 hover:shadow-lg hover:shadow-accent-500/10"
      >
        <!-- Cover -->
        {post.data.cover ? (
          <div class="w-24 h-24 sm:w-28 sm:h-28 flex-shrink-0 rounded-lg overflow-hidden">
            <img
              src={post.data.cover}
              alt={post.data.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>
        ) : (
          <div class="w-24 h-24 sm:w-28 sm:h-28 flex-shrink-0 rounded-lg bg-gray-100 dark:bg-gray-800 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-gray-300 dark:text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
        )}

        <!-- Text -->
        <div class="flex flex-col justify-between py-1 min-w-0">
          <div>
            {post.data.tags.length > 0 && (
              <div class="flex flex-wrap gap-1 mb-1">
                {post.data.tags.slice(0, 2).map(tag => (
                  <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-accent-100 dark:bg-accent-900/30 text-accent-600 dark:text-accent-400">
                    {tag}
                  </span>
                ))}
              </div>
            )}
            <h2 class="font-semibold text-sm leading-snug line-clamp-2 group-hover:text-accent-500 transition-colors">
              {post.data.title}
            </h2>
            <p class="text-xs text-gray-500 dark:text-gray-400 line-clamp-1 mt-1">
              {post.data.description}
            </p>
          </div>
          <time class="text-xs text-gray-400 dark:text-gray-500 mt-2">
            {new Intl.DateTimeFormat("en-US", {
              year: "numeric",
              month: "short",
              day: "numeric",
            }).format(post.data.date)}
          </time>
        </div>
      </a>
    ))}
  </div>

  <Footer slot="footer" />
</BaseLayout>
