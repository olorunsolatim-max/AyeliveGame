---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import ShareBar from "@components/ShareBar.astro";
import BackToTop from "@components/BackToTop.astro";
import { getCollection } from "astro:content";
import { SITE } from "../../config";
import ProgressBar from "@components/ProgressBar.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings, remarkPluginFrontmatter } = await post.render();

const allPosts = await getCollection(
  "blog",
  ({ data }) => !data.draft
);

// Reading time
const readingTime =
  remarkPluginFrontmatter?.readingTime ??
  Math.ceil((post.body?.split(/\s+/)?.length ?? 0) / 200);

// Related posts
const relatedPosts = allPosts
  .filter(
    (p) =>
      p.slug !== post.slug &&
      p.data.tags?.length > 0 &&
      post.data.tags?.length > 0 &&
      p.data.tags.some((tag) => post.data.tags.includes(tag))
  )
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const formattedDate = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
}).format(post.data.date);

const siteUrl = Astro.site?.toString() ?? SITE.url;

const postUrl = new URL(
  `/blog/${post.slug}/`,
  siteUrl
).toString();

// TOC
const tocHeadings = headings.filter(
  (h) => h.depth === 2 || h.depth === 3
);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.cover}
>
<ProgressBar />
  <Header slot="header" />

  <article class="max-w-2xl mx-auto">

    <!-- Breadcrumbs -->
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 flex-wrap">
        <li>
          <a href="/" class="hover:text-accent-500 transition-colors">
            Home
          </a>
        </li>

        <li class="text-gray-300 dark:text-gray-600">/</li>

        <li>
          <a href="/blog/" class="hover:text-accent-500 transition-colors">
            Blog
          </a>
        </li>

        {post.data.tags?.[0] && (
          <>
            <li class="text-gray-300 dark:text-gray-600">/</li>

            <li>
              <a
                href={`/tags/${post.data.tags[0]}/`}
                class="hover:text-accent-500 transition-colors"
              >
                {post.data.tags[0]}
              </a>
            </li>
          </>
        )}

        <li class="text-gray-300 dark:text-gray-600">/</li>

        <li class="text-gray-900 dark:text-gray-100 font-medium line-clamp-1 max-w-xs">
          {post.data.title}
        </li>
      </ol>
    </nav>

    <!-- Breadcrumb JSON-LD -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: [
          {
            "@type": "ListItem",
            position: 1,
            name: "Home",
            item: siteUrl,
          },
          {
            "@type": "ListItem",
            position: 2,
            name: "Blog",
            item: new URL("/blog/", siteUrl).toString(),
          },
          ...(post.data.tags?.[0]
            ? [
                {
                  "@type": "ListItem",
                  position: 3,
                  name: post.data.tags[0],
                  item: new URL(
                    `/tags/${post.data.tags[0]}/`,
                    siteUrl
                  ).toString(),
                },
              ]
            : []),
          {
            "@type": "ListItem",
            position: post.data.tags?.[0] ? 4 : 3,
            name: post.data.title,
            item: postUrl,
          },
        ],
      })}
    />

    <!-- Tags -->
    {post.data.tags?.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-4">
        {post.data.tags.map((tag) => (
          <a
            href={`/tags/${tag}/`}
            class="text-xs font-medium px-2 py-0.5 rounded-full bg-accent-100 dark:bg-accent-900/30 text-accent-600 dark:text-accent-400 hover:bg-accent-200 transition-colors"
          >
            #{tag}
          </a>
        ))}
      </div>
    )}

    <!-- Title -->
    <h1 class="text-3xl font-bold leading-tight mb-4">
      {post.data.title}
    </h1>

    <!-- Meta -->
    <div class="flex items-center gap-3 text-sm text-gray-500 dark:text-gray-400 mb-8 pb-8 border-b border-gray-200 dark:border-gray-800">
      <span>{post.data.author}</span>

      <span>·</span>

      <time datetime={post.data.date.toISOString()}>
        {formattedDate}
      </time>

      <span>·</span>

      <span>{readingTime} min read</span>
    </div>

    <!-- Share -->
    <div class="py-4 mb-6 border-t border-b border-gray-200 dark:border-gray-800">
      <ShareBar title={post.data.title} url={postUrl} />
    </div>

    <!-- Cover -->
    {post.data.cover && (
      <img
        src={post.data.cover}
        alt={post.data.title}
        class="w-full rounded-xl mb-8 object-cover max-h-96"
        loading="eager"
        width="1200"
        height="630"
      />
    )}

    <!-- Article JSON-LD -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        headline: post.data.title,
        description: post.data.description,

        image: post.data.cover
          ? post.data.cover.startsWith("http")
            ? post.data.cover
            : new URL(post.data.cover, siteUrl).toString()
          : new URL(SITE.ogImage, siteUrl).toString(),

        author: {
          "@type": "Person",
          name: post.data.author,
          url: siteUrl,
        },

        publisher: {
          "@type": "Organization",
          name: SITE.name,
          url: siteUrl,
        },

        datePublished: post.data.date.toISOString(),

        dateModified: post.data.updated
          ? new Date(post.data.updated).toISOString()
          : post.data.date.toISOString(),

        mainEntityOfPage: {
          "@type": "WebPage",
          "@id": postUrl,
        },

        keywords: post.data.tags?.join(", ") ?? "",

        url: postUrl,
      })}
    />

    <!-- TOC -->
    {tocHeadings.length > 2 && (
      <nav
        aria-label="Table of Contents"
        class="mb-8 p-5 rounded-xl border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900"
      >
        <h2 class="text-sm font-semibold uppercase tracking-widest text-accent-500 mb-4">
          Table of Contents
        </h2>

        <ul class="space-y-2">
          {tocHeadings.map((heading) => (
            <li class={heading.depth === 3 ? "ml-4" : ""}>
              <a
                href={`#${heading.slug}`}
                class="text-sm text-gray-600 dark:text-gray-400 hover:text-accent-500 transition-colors"
              >
                {heading.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    )}

    <!-- Content -->
<div class="prose prose-gray dark:prose-invert max-w-none mb-12">
  <Content />
</div>

<!-- Wrap tables for scroll -->
<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    const tables = document.querySelectorAll('.prose table');
    tables.forEach(table => {
      if (!table.parentElement.classList.contains('table-wrapper')) {
        const wrapper = document.createElement('div');
        wrapper.className = 'table-wrapper';
        table.parentNode.insertBefore(wrapper, table);
        wrapper.appendChild(table);
      }
    });
  });
</script>

    <!-- Related Posts -->
    {relatedPosts.length > 0 && (
      <aside class="mb-12">
        <h2 class="text-sm font-semibold uppercase tracking-widest text-accent-500 mb-6">
          Related Posts
        </h2>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {relatedPosts.map((related) => (
            <a
              href={`/blog/${related.slug}/`}
              class="group rounded-xl border border-gray-200 dark:border-gray-800 hover:border-accent-500 transition-all duration-300 overflow-hidden"
            >
              {related.data.cover ? (
                <div class="h-32 overflow-hidden">
                  <img
                    src={related.data.cover}
                    alt={related.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                    width="400"
                    height="200"
                  />
                </div>
              ) : (
                <div class="h-32 bg-gray-100 dark:bg-gray-800 flex items-center justify-center">
                  No Image
                </div>
              )}

              <div class="p-3">
                <h3 class="text-sm font-semibold line-clamp-2 group-hover:text-accent-500 transition-colors">
                  {related.data.title}
                </h3>

                <time class="text-xs text-gray-400 mt-1 block">
                  {new Intl.DateTimeFormat("en-US", {
                    month: "short",
                    day: "numeric",
                    year: "numeric",
                  }).format(related.data.date)}
                </time>
              </div>
            </a>
          ))}
        </div>
      </aside>
    )}
  </article>

  <BackToTop />
  <Footer slot="footer" />
</BaseLayout>
