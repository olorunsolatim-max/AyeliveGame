---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);

const sortedPosts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Author — MyBlog">
  <Header slot="header" />

  <div class="max-w-2xl mx-auto">

    <!-- Author Card -->
    <div class="flex items-center gap-5 mb-12 p-6 rounded-2xl border border-gray-200 dark:border-gray-800">
      <div class="w-20 h-20 rounded-full bg-accent-500 flex items-center justify-center text-white text-2xl font-bold flex-shrink-0">
        M
      </div>
      <div>
        <h1 class="text-2xl font-bold mb-1">Admin</h1>
        <p class="text-gray-500 dark:text-gray-400 text-sm mb-3">
          Writer, developer, and tech enthusiast. Building MyBlog to share
          knowledge about technology, smartphones, and the web.
        </p>
        <div class="flex items-center gap-3">
          <a
            href="https://x.com/ByteCascade1"
            target="_blank"
            class="text-xs text-accent-500 hover:underline"
          >
            Twitter
          </a>
          <a
            href="https://github.com/bytecascade11/"
            target="_blank"
            class="text-xs text-accent-500 hover:underline"
          >
            GitHub
          </a>
        </div>
      </div>
    </div>

    <!-- Author Posts -->
    <h2 class="text-sm font-semibold uppercase tracking-widest text-accent-500 mb-6">
      All Posts · {sortedPosts.length}
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      {sortedPosts.map(post => (
        <a
          href={`/blog/${post.slug}`}
          class="group flex gap-4 rounded-xl border border-gray-200 dark:border-gray-800 hover:border-accent-500 transition-all duration-300 p-3 hover:shadow-lg hover:shadow-accent-500/10"
        >
          {post.data.cover ? (
            <div class="w-24 h-24 flex-shrink-0 rounded-lg overflow-hidden">
              <img
                src={post.data.cover}
                alt={post.data.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
            </div>
          ) : (
            <div class="w-24 h-24 flex-shrink-0 rounded-lg bg-gray-100 dark:bg-gray-800 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-gray-300 dark:text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
          )}

          <div class="flex flex-col justify-between py-1 min-w-0">
            <div>
              {post.data.tags.length > 0 && (
                <span class="text-xs font-medium text-accent-500 mb-1 block">
                  {post.data.tags[0]}
                </span>
              )}
              <h3 class="font-semibold text-sm leading-snug line-clamp-2 group-hover:text-accent-500 transition-colors">
                {post.data.title}
              </h3>
            </div>
            <time class="text-xs text-gray-400 dark:text-gray-500 mt-2">
              {new Intl.DateTimeFormat("en-US", {
                year: "numeric",
                month: "short",
                day: "numeric",
              }).format(post.data.date)}
            </time>
          </div>
        </a>
      ))}
    </div>

  </div>

  <Footer slot="footer" />
</BaseLayout>
