---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";

const lastUpdated = "June 5, 2026";
---

<BaseLayout title="Disclaimer — AyeliveGame">
  <Header slot="header" />

  <div class="max-w-2xl mx-auto">
    <h1 class="text-3xl font-bold mb-2">Disclaimer</h1>
    <p class="text-sm text-gray-400 mb-10">Last updated: {lastUpdated}</p>

    <div class="prose prose-gray dark:prose-invert max-w-none">
      <p>
        The information published on AyeliveGame is provided for general
        informational and educational purposes only. While we strive to keep
        our content accurate, up to date, and reliable, we make no guarantees
        regarding the completeness, accuracy, reliability, suitability, or
        availability of any information found on this website.
      </p>

      <h2>Content Accuracy</h2>
      <p>
        Gaming content, including guides, rankings, updates, patch notes,
        strategies, and opinions, may become outdated as games receive updates
        and changes from developers. Readers should verify information through
        official game sources when making decisions based on content published
        on this website.
      </p>

      <h2>Not Professional Advice</h2>
      <p>
        The content available on AyeliveGame does not constitute professional,
        legal, financial, technical, or other specialized advice. Any actions
        taken based on information found on this website are strictly at your
        own risk.
      </p>

      <h2>Opinions and Reviews</h2>
      <p>
        Reviews, rankings, recommendations, and opinions expressed on
        AyeliveGame represent our honest views and experiences. Individual
        opinions may differ, and we encourage readers to conduct their own
        research before making purchasing or gaming-related decisions.
      </p>

      <h2>Affiliate Disclosure</h2>
      <p>
        Some articles may contain affiliate links. If you click on an affiliate
        link and make a purchase, we may earn a commission at no additional
        cost to you. These commissions help support the operation and maintenance
        of AyeliveGame.
      </p>

      <p>
        We only recommend products, services, or tools that we believe may be
        valuable to our audience. However, readers should independently evaluate
        any product or service before making a purchase.
      </p>

      <h2>Advertising</h2>
      <p>
        AyeliveGame may display advertisements through third-party advertising
        networks, including Google AdSense. Advertisements displayed on this
        website do not constitute endorsements or recommendations unless
        explicitly stated.
      </p>

      <h2>External Links</h2>
      <p>
        Our website may contain links to external websites for additional
        information or resources. We do not control the content, policies,
        or practices of third-party websites and are not responsible for any
        information, products, or services they provide.
      </p>

      <h2>Limitation of Liability</h2>
      <p>
        Under no circumstances shall AyeliveGame, its owner, contributors,
        or affiliates be held liable for any loss, damage, or inconvenience
        arising from the use of this website or reliance on any information
        provided herein.
      </p>

      <h2>Changes to This Disclaimer</h2>
      <p>
        We reserve the right to update, modify, or replace this Disclaimer at
        any time without prior notice. Changes will be posted on this page with
        an updated revision date.
      </p>

      <h2>Contact Us</h2>
      <p>
        If you have any questions regarding this Disclaimer, please
        <a href="/contact">contact us</a>.
      </p>
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>
