---
// TableScrollInit.astro
// Add once to your base layout, just before </body>
---

<script>
  function initTableScroll() {
    document.querySelectorAll<HTMLElement>(".prose table").forEach((table) => {
      // Avoid double-wrapping
      if (table.closest(".table-fade-wrap")) return;

      // Create outer card wrapper
      const wrap = document.createElement("div");
      wrap.className = "table-fade-wrap";

      // Create inner scroll div
      const inner = document.createElement("div");
      inner.className = "table-scroll-inner";

      // Insert: wrap > inner > table
      table.parentNode!.insertBefore(wrap, table);
      wrap.appendChild(inner);
      inner.appendChild(table);

      // Fade edge: show when table overflows AND not scrolled to end
      const update = () => {
        const overflowing = inner.scrollWidth > inner.clientWidth;
        const atEnd = inner.scrollLeft + inner.clientWidth >= inner.scrollWidth - 8;
        wrap.classList.toggle("is-overflowing", overflowing && !atEnd);
      };

      inner.addEventListener("scroll", update, { passive: true });
      new ResizeObserver(update).observe(inner);
      update();
    });
  }

  // Run on first load
  initTableScroll();

  // Re-run after Astro view transitions (if you use them)
  document.addEventListener("astro:page-load", initTableScroll);
</script>
