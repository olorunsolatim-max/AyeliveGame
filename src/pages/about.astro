---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
---

<BaseLayout title="About — AyeliveGame">
  <Header slot="header" />

  <div class="max-w-2xl mx-auto">
    <h1 class="text-3xl font-bold mb-6">About</h1>

    <div class="prose prose-gray dark:prose-invert max-w-none">
      <p>
        Welcome to AyeliveGame — your destination for gaming news, guides,
        tips, rankings, and updates from some of the most popular games in the world.
        Our goal is to help players stay informed, improve their skills, and enjoy
        their favorite games with useful and easy-to-follow content.
      </p>

      <h2>Who runs this?</h2>
      <p>
        AyeliveGame is independently managed by a passionate gamer and content creator
        who enjoys exploring new games, testing strategies, and sharing insights with
        the gaming community. Every article is written with the aim of providing
        valuable information for both casual and competitive players.
      </p>

      <h2>What do we write about?</h2>
      <ul>
        <li>Gaming news and industry updates</li>
        <li>Call of Duty: Mobile (CODM) guides and loadouts</li>
        <li>eFootball tips, formations, and player recommendations</li>
        <li>Dream League Soccer strategies and team-building guides</li>
        <li>Mortal Kombat news, characters, and gameplay tips</li>
        <li>Game rankings, reviews, and trending gaming topics</li>
      </ul>

      <h2>Our mission</h2>
      <p>
        We believe gaming content should be accurate, helpful, and accessible.
        That's why we focus on creating content that helps players make better
        decisions, discover new strategies, and stay up to date with the latest
        developments in their favorite games.
      </p>

      <h2>Get in touch</h2>
      <p>
        Have a question, suggestion, or collaboration opportunity?
        <a href="/contact">Send us a message</a>.
      </p>

      <p>
        Thank you for visiting AyeliveGame and being part of our growing gaming community.
      </p>
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>
