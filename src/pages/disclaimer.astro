---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";

const lastUpdated = "January 1, 2025";
---

<BaseLayout title="Disclaimer — MyBlog">
  <Header slot="header" />

  <div class="max-w-2xl mx-auto">
    <h1 class="text-3xl font-bold mb-2">Disclaimer</h1>
    <p class="text-sm text-gray-400 mb-10">Last updated: {lastUpdated}</p>

    <div class="prose prose-gray dark:prose-invert max-w-none">
      <p>
        The information provided on this blog is for general informational
        purposes only. We make no representations or warranties of any kind
        about the completeness or accuracy of this information.
      </p>

      <h2>Not Professional Advice</h2>
      <p>
        Nothing on this site constitutes professional, legal, financial,
        or technical advice. Always do your own research before making decisions.
      </p>

      <h2>Affiliate Links</h2>
      <p>
        Some posts may contain affiliate links. This means we may earn a small
        commission if you make a purchase through those links, at no extra cost to you.
      </p>

      <h2>Reviews</h2>
      <p>
        All reviews and opinions expressed on this blog are our own and are
        not influenced by manufacturers or advertisers.
      </p>

      <h2>Contact</h2>
      <p>
        Questions? <a href="/contact">Get in touch</a>.
      </p>
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>
