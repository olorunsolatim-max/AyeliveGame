---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import PostCard from "@components/PostCard.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);

const sortedPosts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const heroPost = sortedPosts[0];
const recentPosts = sortedPosts.slice(1, 7);
---

<BaseLayout title="MyBlog — A Fast Tech Blog">
  <Header slot="header" />

  <!-- HERO: Latest Post -->
  {heroPost && (
    <section class="mb-12">
      <a
        href={`/blog/${heroPost.slug}`}
        class="group block rounded-2xl overflow-hidden border border-gray-200 dark:border-gray-800 hover:border-accent-500 transition-all duration-300 hover:shadow-xl hover:shadow-accent-500/10"
      >
        <!-- Cover Image -->
        {heroPost.data.cover ? (
          <div class="relative w-full h-72 sm:h-96 overflow-hidden">
            <img
              src={heroPost.data.cover}
              alt={heroPost.data.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="eager"
            />
            <!-- Gradient overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent" />
            <!-- Text over image -->
            <div class="absolute bottom-0 left-0 right-0 p-6">
              <div class="flex flex-wrap gap-2 mb-3">
                {heroPost.data.tags.map(tag => (
                  <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-accent-500/90 text-white">
                    {tag}
                  </span>
                ))}
              </div>
              <h1 class="text-2xl sm:text-3xl font-bold text-white leading-snug mb-2">
                {heroPost.data.title}
              </h1>
              <p class="text-gray-300 text-sm line-clamp-2">
                {heroPost.data.description}
              </p>
              <div class="mt-3 text-xs text-gray-400">
                {heroPost.data.author} · {new Intl.DateTimeFormat("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                }).format(heroPost.data.date)}
              </div>
            </div>
          </div>
        ) : (
          <div class="p-8">
            <h1 class="text-3xl font-bold mb-3 group-hover:text-accent-500 transition-colors">
              {heroPost.data.title}
            </h1>
            <p class="text-gray-500 dark:text-gray-400">
              {heroPost.data.description}
            </p>
          </div>
        )}
      </a>
    </section>
  )}

  <!-- RECENT POSTS -->
  {recentPosts.length > 0 && (
    <section class="mb-10">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-sm font-semibold uppercase tracking-widest text-accent-500">
          Recent Posts
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        {recentPosts.map(post => (
          <a
            href={`/blog/${post.slug}`}
            class="group flex gap-4 rounded-xl border border-gray-200 dark:border-gray-800 hover:border-accent-500 transition-all duration-300 p-3 hover:shadow-lg hover:shadow-accent-500/10"
          >
            <!-- Small Cover -->
            {post.data.cover ? (
              <div class="w-24 h-24 sm:w-28 sm:h-28 flex-shrink-0 rounded-lg overflow-hidden">
                <img
                  src={post.data.cover}
                  alt={post.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
              </div>
            ) : (
              <div class="w-24 h-24 sm:w-28 sm:h-28 flex-shrink-0 rounded-lg bg-gray-100 dark:bg-gray-800 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-gray-300 dark:text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
            )}

            <!-- Text -->
            <div class="flex flex-col justify-between py-1 min-w-0">
              <div>
                {post.data.tags.length > 0 && (
                  <span class="text-xs font-medium text-accent-500 mb-1 block">
                    {post.data.tags[0]}
                  </span>
                )}
                <h3 class="font-semibold text-sm leading-snug line-clamp-2 group-hover:text-accent-500 transition-colors">
                  {post.data.title}
                </h3>
              </div>
              <time class="text-xs text-gray-400 dark:text-gray-500 mt-2">
                {new Intl.DateTimeFormat("en-US", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                }).format(post.data.date)}
              </time>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}
<div class="flex flex-wrap gap-2 mb-3">
  {heroPost.data.tags.map(tag => (
    <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-accent-500/90 text-white">
      {tag}
    </span>
  ))}
</div>
  <!-- VIEW MORE -->
  <div class="text-center mb-12">
    <a
      href="/blog"
      class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-gray-200 dark:border-gray-700 text-sm font-medium hover:border-accent-500 hover:text-accent-500 transition-all duration-200"
    >
      View All Posts
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>

  <Footer slot="footer" />
</BaseLayout>
