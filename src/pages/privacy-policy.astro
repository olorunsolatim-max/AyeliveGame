---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";

const lastUpdated = "January 1, 2025";
---

<BaseLayout title="Privacy Policy — MyBlog">
  <Header slot="header" />

  <div class="max-w-2xl mx-auto">
    <h1 class="text-3xl font-bold mb-2">Privacy Policy</h1>
    <p class="text-sm text-gray-400 mb-10">Last updated: {lastUpdated}</p>

    <div class="prose prose-gray dark:prose-invert max-w-none">
      <p>
        Your privacy is important to us. This policy explains what information
        we collect, how we use it, and your rights regarding your data.
      </p>

      <h2>Information We Collect</h2>
      <p>
        We may collect basic analytics data such as page views and referral sources
        through privacy-friendly analytics tools. We do not collect personally
        identifiable information unless you contact us directly.
      </p>

      <h2>Cookies</h2>
      <p>
        This site may use cookies to remember your preferences such as dark mode.
        No tracking cookies are used without your consent.
      </p>

      <h2>Third Party Services</h2>
      <p>
        We may use third party services such as Google AdSense or analytics tools
        that have their own privacy policies. We encourage you to review them.
      </p>

      <h2>Contact</h2>
      <p>
        If you have questions about this policy, please
        <a href="/contact">contact us</a>.
      </p>
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>
